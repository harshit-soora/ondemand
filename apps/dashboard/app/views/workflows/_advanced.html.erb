<%#
  Advanced overrides form for a workflow.

  Renders a collapsible card whose body re-uses the same launcher
  smart-attribute widgets, restricted to the six fields that make sense
  to override at the workflow level: account, environment variable, queue,
  cluster, hours, job name.

  Fields here render with their native launcher[<id>] name, just like on
  the launcher edit page. The workflows controller re-maps params[:launcher]
  into workflow.advanced_overrides on submit, so the same launcher_edit.js
  works unchanged.

  Values stored in advanced_overrides are merged over each launcher's own
  params at workflow submit time. They do NOT mutate the per-launcher
  form.yml or its cache, so a solo launch of the same launcher is unaffected.

  The companion workflow_advanced.js trims launcher_edit.js's "Add new
  option" dropdown to our six allowed fields and keeps env vars repeatable.
%>
<%= javascript_include_tag 'launcher_edit', nonce: true, defer: true %>
<%= javascript_include_tag 'workflow_advanced', nonce: true, defer: true %>

<div class="card mt-3" id="workflow_advanced_card">
  <div class="card-body">
    <h5 class="card-title">
      <%= t('dashboard.jobs_workflow_advanced_overrides_title') %>
      <%= form_label_tooltip(t('dashboard.jobs_workflow_advanced_overrides_help')).html_safe %>
    </h5>

    <p class="text-muted small mb-3">
      <%= t('dashboard.jobs_workflow_advanced_overrides_description') %>
    </p>

    <%# Render each currently-configured override using the same widget
        renderer the launcher edit page uses. We pass a launcher-bound
        FormBuilder (script_form_double from LaunchersHelper) so the
        widgets render their fields with name="launcher[<id>]" — matching
        what launcher_edit.js expects and what the controller re-maps into
        advanced_overrides on submit. %>
    <% @workflow_overrides.each do |attrib| %>
      <%= create_editable_widget(script_form_double, attrib, format: nil) %>
    <% end %>

    <%# Re-use the launcher "add new option" partial verbatim so the same
        templates (#bc_num_hours_template, #auto_queues_template, ...) drive
        the dropdown of additional fields the user can add. %>
    <%= render partial: 'launchers/add_new_field' %>
  </div>
</div>

<%# launcher_edit.js clones a <template> by id (e.g. #auto_queues_template)
    when the user clicks "Add". Those <template> blocks live on the launcher
    edit page; the workflow page doesn't have them. Re-render only the six
    we want to expose at the workflow level so "Add" actually inserts a
    field. Anything not rendered here also won't be installable, even if
    launcher_edit.js's newFieldData lists it. %>
<template id="bc_num_hours_template">
  <%= bc_num_hours_template %>
</template>

<template id="auto_queues_template">
  <%= auto_queues_template %>
</template>

<template id="auto_accounts_template">
  <%= auto_accounts_template %>
</template>

<template id="auto_job_name_template">
  <%= auto_job_name_template %>
</template>

<template id="auto_environment_variable_template">
  <%= auto_environment_variable_template %>
</template>

<template id="auto_batch_clusters_template">
  <%# Re-use the same widget renderer the launcher edit page uses.
      LaunchersHelper doesn't ship an auto_batch_clusters_template helper,
      so we build the smart attribute inline. %>
  <%= create_editable_widget(script_form_double,
        SmartAttributes::AttributeFactory.build('auto_batch_clusters', {})) %>
</template>
